export default function App() {
  const [variantIndex, setVariantIndex] = useState(0);
  const [isDarkMode, setIsDarkMode] = useState(true);
  const [isLoading, setIsLoading] = useState(true);
  const [isVariantLoading, setIsVariantLoading] = useState(false);
  const [loadProgress, setLoadProgress] = useState(0);
  const [loadedImages, setLoadedImages] = useState<HTMLImageElement[]>([]);
  
  const currentVariant = DRINK_VARIANTS[variantIndex];
  const canvasRef = useRef<HTMLCanvasElement>(null);
  
  const heroRef = useRef<HTMLDivElement>(null);
  
  // Scroll tracking for parallax
  const { scrollYProgress } = useScroll({
    target: heroRef,
    offset: ["start start", "end start"]
  });
  const smoothProgress = useSpring(scrollYProgress, { stiffness: 1000, damping: 100, restDelta: 0.001 });
  
  // Map scroll progress to frame index (0 to 199)
  // We use raw scrollYProgress for the frame index to ensure perfect, zero-lag sync with the scroll.
  // With 400vh height, sticky ends at 0.75 progress (300vh scroll).
  // We'll map the entire 200 frames to play linearly over the first 0.6 of the scroll
  // to ensure the animation finishes while the user is still in the sticky phase.
  const frameIndex = useTransform(
    scrollYProgress, 
    [0, 0.6], 
    [0, currentVariant.frameCount - 1], 
    { clamp: true }
  );

  // Preload initial variant
  useEffect(() => {
    const preloadImages = async () => {
      setIsVariantLoading(true);
      setLoadedImages([]); // Clear old images immediately
      
      // Clear canvas
      if (canvasRef.current) {
        const ctx = canvasRef.current.getContext('2d');
        ctx?.clearRect(0, 0, canvasRef.current.width, canvasRef.current.height);
      }

      const images: HTMLImageElement[] = [];
      let loadedCount = 0;
      
      const totalFrames = currentVariant.frameCount;
      
      const loadPromises = Array.from({ length: totalFrames }).map((_, i) => {
        return new Promise<void>((resolve) => {
          const img = new Image();
          img.src = getFrameUrl(currentVariant.baseUrl, i);
          img.onload = () => {
            loadedCount++;
            setLoadProgress((loadedCount / totalFrames) * 100);
            images[i] = img;
            resolve();
          };
          img.onerror = () => {
            loadedCount++;
            resolve();
          };
        });
      });

      await Promise.all(loadPromises);
      setLoadedImages(images);
      setIsLoading(false);
      setIsVariantLoading(false);
    };

    preloadImages();
  }, [variantIndex]);

  // Draw frame to canvas
  const drawFrame = (val: number, images: HTMLImageElement[]) => {
    const index = Math.floor(val);
    if (canvasRef.current && images[index]) {
      const ctx = canvasRef.current.getContext('2d');
      if (ctx) {
        ctx.clearRect(0, 0, canvasRef.current.width, canvasRef.current.height);
        ctx.drawImage(images[index], 0, 0, canvasRef.current.width, canvasRef.current.height);
      }
    }
  };

  useEffect(() => {
    // Draw current frame whenever images change or scroll changes
    drawFrame(frameIndex.get(), loadedImages);

    const unsubscribe = frameIndex.on("change", (latest) => {
      drawFrame(latest, loadedImages);
    });
    return () => unsubscribe();
  }, [loadedImages, frameIndex]);

  const handleNext = () => {
    setVariantIndex((prev) => (prev + 1) % DRINK_VARIANTS.length);
  };

  const handlePrev = () => {
    setVariantIndex((prev) => (prev - 1 + DRINK_VARIANTS.length) % DRINK_VARIANTS.length);
  };

  return (
    <div className={`min-h-screen transition-colors duration-700 ${isDarkMode ? 'bg-black text-white' : 'bg-[#F9F9F9] text-black'} selection:bg-white selection:text-black font-sans overflow-x-hidden`}>
      <AnimatePresence>
        {isLoading && <LoadingScreen progress={loadProgress} brandName="Olipop" />}
      </AnimatePresence>

      <Navbar 
        brandName="Olipop" 
        themeColor={currentVariant.themeColor} 
        isDarkMode={isDarkMode}
        toggleDarkMode={() => setIsDarkMode(!isDarkMode)}
      />

      {/* --- HERO SECTION --- */}
      <section ref={heroRef} className="relative h-[400vh] w-full">
        <div className="sticky top-0 h-screen w-full overflow-hidden">
          {/* Background Sequence */}
          <motion.canvas 
            key={variantIndex}
            ref={canvasRef}
            width={1920}
            height={1080}
            className="absolute inset-0 w-full h-full object-cover pointer-events-none"
            style={{ 
              opacity: useTransform(smoothProgress, [0.75, 0.9], [1, 0])
            }}
          />
          
          {/* Overlay Content */}
          <motion.div 
            style={{ 
              y: useTransform(smoothProgress, [0, 0.6], [0, -150]),
              opacity: useTransform(smoothProgress, [0.4, 0.6], [1, 0])
            }}
            className="relative z-10 h-full max-w-7xl mx-auto px-8 flex items-center"
          >
            <div className="w-full md:w-1/2">
              <AnimatePresence mode="wait">
                <motion.div
                  key={currentVariant.id}
                  initial="hidden"
                  animate="visible"
                  exit="exit"
                  variants={{
                    hidden: { opacity: 0 },
                    visible: { 
                      opacity: 1,
                      transition: { staggerChildren: 0.08, delayChildren: 0.1 }
                    },
                    exit: { 
                      opacity: 0,
                      transition: { duration: 0.4, ease: "easeInOut" }
                    }
                  }}
                >
                  <motion.h2 
                    variants={{
                      hidden: { opacity: 0, y: 15 },
                      visible: { opacity: 1, y: 0 },
                      exit: { opacity: 0, y: -10 }
                    }}
                    transition={{ duration: 0.8, ease: [0.16, 1, 0.3, 1] }}
                    className={`text-xl font-light tracking-[0.3em] mb-2 transition-colors duration-700 ${isDarkMode ? 'text-white/60' : 'text-black/60'}`}
                  >
                    {currentVariant.subtitle}
                  </motion.h2>
                  <motion.h1 
                    variants={{
                      hidden: { opacity: 0, y: 25 },
                      visible: { opacity: 1, y: 0 },
                      exit: { opacity: 0, y: -15 }
                    }}
                    transition={{ duration: 0.8, ease: [0.16, 1, 0.3, 1] }}
                    className="text-8xl md:text-9xl font-black tracking-tighter leading-none mb-6"
                  >
                    {currentVariant.name}
                  </motion.h1>
                  <motion.p 
                    variants={{
                      hidden: { opacity: 0, y: 20 },
                      visible: { opacity: 1, y: 0 },
                      exit: { opacity: 0, y: -10 }
                    }}
                    transition={{ duration: 0.8, ease: [0.16, 1, 0.3, 1] }}
                    className={`text-lg max-w-md leading-relaxed mb-10 transition-colors duration-700 ${isDarkMode ? 'text-white/70' : 'text-black/70'}`}
                  >
                    {currentVariant.description}
                  </motion.p>
                  
                  <motion.div 
                    variants={{
                      hidden: { opacity: 0, y: 20 },
                      visible: { opacity: 1, y: 0 },
                      exit: { opacity: 0, y: -10 }
                    }}
                    transition={{ duration: 0.8, ease: [0.16, 1, 0.3, 1] }}
                    className="flex gap-4"
                  >
                    <button 
                      className={`px-8 py-4 rounded-full border font-bold tracking-widest text-xs transition-all duration-300 uppercase cursor-pointer ${isDarkMode ? 'border-white text-white hover:bg-white hover:text-black' : 'border-black text-black hover:bg-black hover:text-white'}`}
                    >
                      Add To
                    </button>
                    <button 
                      style={{ backgroundColor: currentVariant.themeColor }}
                      className="px-10 py-4 rounded-full text-black font-black tracking-widest text-xs hover:scale-105 transition-all duration-300 uppercase shadow-lg cursor-pointer"
                    >
                      Cart
                    </button>
                  </motion.div>
                </motion.div>
              </AnimatePresence>
            </div>
            
            {/* Right Side Navigation */}
            <div className="absolute right-8 top-1/2 -translate-y-1/2 flex items-center gap-12 z-20">
              <div className="relative">
                <AnimatePresence mode="wait">
                  <motion.span 
                    key={variantIndex}
                    initial={{ opacity: 0, scale: 0.8 }}
                    animate={{ opacity: 1, scale: 1 }}
                    exit={{ opacity: 0, scale: 1.2 }}
                    className={`text-[12rem] font-black leading-none select-none transition-colors duration-700 ${isDarkMode ? 'text-white/5' : 'text-black/5'}`}
                  >
                    0{variantIndex + 1}
                  </motion.span>
                </AnimatePresence>
                
                <div className="absolute inset-0 flex flex-col items-center justify-center gap-4">
                  <button 
                    onClick={handlePrev}
                    className="flex flex-col items-center gap-2 group cursor-pointer z-30"
                  >
                    <span className={`text-[10px] tracking-[0.4em] transition-colors uppercase ${isDarkMode ? 'text-white/40 group-hover:text-white' : 'text-black/40 group-hover:text-black'}`}>Prev</span>
                    <ChevronLeft className={`transition-colors ${isDarkMode ? 'text-white/40 group-hover:text-white' : 'text-black/40 group-hover:text-black'}`} size={20} />
                  </button>
                  
                  <div className={`h-20 w-px transition-colors duration-700 ${isDarkMode ? 'bg-white/10' : 'bg-black/10'}`} />
                  
                  <button 
                    onClick={handleNext}
                    className="flex flex-col items-center gap-2 group cursor-pointer z-30"
                  >
                    <ChevronRight className={`transition-colors ${isDarkMode ? 'text-white/40 group-hover:text-white' : 'text-black/40 group-hover:text-black'}`} size={20} />
                    <span className={`text-[10px] tracking-[0.4em] transition-colors uppercase ${isDarkMode ? 'text-white/40 group-hover:text-white' : 'text-black/40 group-hover:text-black'}`}>Next</span>
                  </button>
                </div>
              </div>
            </div>
          </motion.div>

          {/* Social Icons Bottom Center */}
          <div className="absolute bottom-12 left-1/2 -translate-x-1/2 flex gap-8 z-10">
            <a href="#" className={`transition-colors ${isDarkMode ? 'text-white/30 hover:text-white' : 'text-black/30 hover:text-black'}`}><Instagram size={18} /></a>
            <a href="#" className={`transition-colors ${isDarkMode ? 'text-white/30 hover:text-white' : 'text-black/30 hover:text-black'}`}><Twitter size={18} /></a>
            <a href="#" className={`transition-colors ${isDarkMode ? 'text-white/30 hover:text-white' : 'text-black/30 hover:text-black'}`}><Facebook size={18} /></a>
          </div>

          {/* Variant Loading Indicator */}
          {isVariantLoading && !isLoading && (
            <div className="absolute bottom-12 right-12 z-20 flex items-center gap-3">
              <div className="w-4 h-4 border-2 border-white/20 border-t-white rounded-full animate-spin" />
              <span className="text-[10px] tracking-widest text-white/50 uppercase">Loading Sequence...</span>
            </div>
          )}
        </div>
      </section>

      {/* --- PRODUCT SECTION --- */}
      <section id="product" className={`py-32 px-8 transition-colors duration-700 ${isDarkMode ? 'bg-neutral-950 text-white' : 'bg-white text-black'}`}>
        <div className="max-w-7xl mx-auto grid md:grid-cols-2 gap-24 items-center">
          <motion.div
