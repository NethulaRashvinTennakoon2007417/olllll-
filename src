                <p className={`text-sm uppercase tracking-widest transition-colors duration-700 ${isDarkMode ? 'text-white/40' : 'text-black/40'}`}>Fiber per can</p>
              </div>
              <div>
                <h4 className="text-3xl font-bold mb-2">2-5g</h4>
                <p className={`text-sm uppercase tracking-widest transition-colors duration-700 ${isDarkMode ? 'text-white/40' : 'text-black/40'}`}>Sugar per can</p>
