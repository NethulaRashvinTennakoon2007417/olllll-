// --- Helper: Generate Frame URL ---
const getFrameUrl = (baseUrl: string, index: number) => {
  const paddedIndex = String(index).padStart(3, '0');
  return `${baseUrl}frame_${paddedIndex}_delay-0.041s.webp`;
};

